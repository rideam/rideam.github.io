import HorizontalCard from "../components/HorizontalCard.astro";
---

<BaseLayout title="Projects" sideBarActiveItemID="services">
  <div>
    <div class="text-3xl w-full font-bold mb-10 mt-6">Services</div>
  </div>

  <!--   img="/post_img.webp"-->
  <HorizontalCard
    title="Software Development"
    desc="We craft robust, scalable, and intuitive software solutions (Web & Mobile) tailored to your unique needs. Our software engineering expertise ensures that your applications are not just functional, but also innovative and ready to meet the challenges of the digital age"
    badge=""
    url="https://amplepalm.com"
  />
  <div class=" my-4"></div>
  <HorizontalCard
    title="Enterprise Resource Planning System"
    desc="Our ERP system is a powerful suite that integrates a wide range of applications to meet various business needs seamlessly. From e-commerce and website management to manufacturing, inventory, accounting, and more, the ERP system offers a versatile platform with all-encompassing functionality."
    badge="NEW"
    url="https://amplepalm.com"
  />
  <div class=" my-4"></div>
  <HorizontalCard
    title="Technical Consultancy"
    desc="Navigate complex technology decisions with confidence. Our expert advisors help you choose the right tech stack, architecture, and tools to meet your business goals without vendor lock-in."
    url="https://amplepalm.com"
  />
